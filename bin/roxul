#!/usr/bin/env node
// Wrapper script for Roxul CLI on Unix-like systems
import path from 'path';
import { fileURLToPath } from 'url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

// Resolve the main CLI script relative to this wrapper
const cliPath = path.resolve(__dirname, '..', 'cli.js');

// Execute the CLI with Node, passing through all arguments
import { spawn } from 'child_process';
const child = spawn('node', [cliPath, ...process.argv.slice(2)], { stdio: 'inherit' });
child.on('close', (code) => process.exit(code));
